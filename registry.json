      "files": [
        { "src": "items/claude/hooks/post-edit-prettier/hook.json", "target": "" }
      ],
      "dependencies": [],
      "hookMerge": {
        "event": "PostToolUse",
        "entry": {
          "matcher": "Edit|Write",
          "hooks": [
            {
              "type": "command",
              "command": "npx prettier --write $CLAUDE_FILE_PATH"
            }
          ]
        }
      }
